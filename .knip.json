{
  "$schema": "./node_modules/knip/schema.json",
  "workspaces": {
    "apps/web": {
      "astro": true
    },
    "packages/*": {
      "astro": false
    },
    "tools/*": {
      "astro": false
    },
    "tools/ascii-art-generator": {
      "ignoreDependencies": ["@types/figlet"]
    },
    "tools/bip39-mnemonic-generator": {
      "ignoreDependencies": ["buffer"]
    },
    "tools/unicode-punycode-converter": {
      "ignoreDependencies": ["punycode", "@types/punycode"]
    }
  }
}
