---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import UnixTimestampConverterClient from "./client"

import type { ToolMeta } from "@workspace/tool-sdk"
import type { UnixTimestampConverterMessages } from "./types"

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<UnixTimestampConverterMessages>(
  import.meta.glob("./messages/*.json", {
    eager: true,
    import: "default",
  }),
  lang
)!
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <UnixTimestampConverterClient client:load language={lang} messages={messages} />
</ToolPageShell>
