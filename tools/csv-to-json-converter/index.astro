---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolArticle } from "@workspace/ui/components/tool/tool-article"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import CsvToJsonConverterClient from "./client"
import "./highlight.css"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"
import type { ToolMeta } from "@workspace/tool-sdk"

type CsvToJsonConverterMessagesCatalog = Readonly<{
  importFromFileLabel: string
  csvLabel: string
  csvDescription: string
  csvPlaceholder: string
  jsonLabel: string
  jsonDescription: string
  downloadJsonLabel: string
  jsonEmptyDescription: string
  invalidCsvLabel: string
  optionsLabel: string
  optionsDescription: string
  noHeaderLabel: string
  headersLabel: string
  headersPlaceholder: string
  delimiterLabel: string
  quoteLabel: string
  trimLabel: string
  checkTypeLabel: string
  skipEmptyLinesLabel: string
  skipEmptyLinesNoneLabel: string
  skipEmptyLinesTrueLabel: string
  skipEmptyLinesGreedyLabel: string
  escapeCharLabel: string
  newlineLabel: string
  previewLabel: string
  commentsLabel: string
  commentsPlaceholder: string
  fastModeLabel: string
  skipFirstNLinesLabel: string
  delimitersToGuessLabel: string
  delimitersToGuessPlaceholder: string
  includeColumnsLabel: string
  ignoreColumnsLabel: string
  regexPlaceholder: string
  indentSizeLabel: string
  indentSizeDescription: string
  copyJsonLabel: string
  copiedLabel: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<CsvToJsonConverterMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const IntroSection = resolveLocale<AstroComponentFactory>(
  import.meta.glob("./sections/intro/*.{md,mdx}", {
    eager: true,
    import: "default",
  }),
  lang
)
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <CsvToJsonConverterClient client:load messages={messages} />

  {
    IntroSection ? (
      <ToolArticle>
        <IntroSection />
      </ToolArticle>
    ) : null
  }
</ToolPageShell>
