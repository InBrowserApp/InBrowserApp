---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import ImageMetadataCleanerClient from "./client"

import type { ToolMeta } from "@workspace/tool-sdk"
import type { ImageMetadataCleanerMessages } from "./client/types"

type ImageMetadataCleanerCatalog = Omit<ImageMetadataCleanerMessages, "meta">

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<ImageMetadataCleanerCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const messages: ImageMetadataCleanerMessages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <ImageMetadataCleanerClient client:load messages={messages} />
</ToolPageShell>
