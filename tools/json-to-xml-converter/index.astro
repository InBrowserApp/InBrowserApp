---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolArticle } from "@workspace/ui/components/tool/tool-article"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import JsonToXmlConverterClient from "./client"
import "./highlight.css"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"
import type { ToolMeta } from "@workspace/tool-sdk"

type JsonToXmlConverterMessagesCatalog = Readonly<{
  importFromFileLabel: string
  downloadXmlLabel: string
  jsonLabel: string
  jsonDescription: string
  xmlLabel: string
  xmlDescription: string
  xmlEmptyDescription: string
  jsonPlaceholder: string
  invalidJsonLabel: string
  invalidXmlTagLabel: string
  optionsLabel: string
  optionsDescription: string
  rootElementLabel: string
  rootElementDescription: string
  arrayItemTagLabel: string
  arrayItemTagDescription: string
  indentSizeLabel: string
  indentSizeDescription: string
  includeDeclarationLabel: string
  includeDeclarationDescription: string
  expandEmptyElementsLabel: string
  expandEmptyElementsDescription: string
  invalidRootElementNameMessage: string
  invalidArrayItemTagMessage: string
  copyXmlLabel: string
  copiedLabel: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<JsonToXmlConverterMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const IntroSection = resolveLocale<AstroComponentFactory>(
  import.meta.glob("./sections/intro/*.{md,mdx}", {
    eager: true,
    import: "default",
  }),
  lang
)
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <JsonToXmlConverterClient client:load messages={messages} />

  {
    IntroSection ? (
      <ToolArticle>
        <IntroSection />
      </ToolArticle>
    ) : null
  }
</ToolPageShell>
