---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import CurrentNetworkTimeClient from "./client"

import type { ToolMeta } from "@workspace/tool-sdk"

type CurrentNetworkTimeMessagesCatalog = Readonly<{
  lastSyncedAt: string
  errorTitle: string
  offset: string
  syncing: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<CurrentNetworkTimeMessagesCatalog>(
  import.meta.glob("./messages/*.json", {
    eager: true,
    import: "default",
  }),
  lang
)!
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <CurrentNetworkTimeClient client:load language={lang} messages={messages} />
</ToolPageShell>
