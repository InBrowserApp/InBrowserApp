---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolArticle } from "@workspace/ui/components/tool/tool-article"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import Base16DecoderClient from "./client"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"
import type { ToolMeta } from "@workspace/tool-sdk"

type Base16DecoderMessagesCatalog = Readonly<{
  base16InputLabel: string
  base16InputPlaceholder: string
  importFromFileLabel: string
  decodedOutputLabel: string
  decodedOutputEmptyDescription: string
  downloadFileLabel: string
  copyResultLabel: string
  copiedLabel: string
  resetLabel: string
  invalidBase16Title: string
  fileReadFailedTitle: string
  previewTruncatedLabel: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<Base16DecoderMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const IntroSection = resolveLocale<AstroComponentFactory>(
  import.meta.glob("./sections/intro/*.{md,mdx}", {
    eager: true,
    import: "default",
  }),
  lang
)
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <Base16DecoderClient client:load messages={messages} />

  {
    IntroSection ? (
      <ToolArticle>
        <IntroSection />
      </ToolArticle>
    ) : null
  }
</ToolPageShell>
