---
import { ToolArticle } from "@workspace/ui/components/tool/tool-article"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import { ToolSurface } from "@workspace/ui/components/tool/tool-surface"
import ImageResizerClient from "./client"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"
import type { ToolMeta } from "@workspace/tool-sdk"

type ImageResizerCopy = Readonly<{
  uploadTitle: string
  uploadDescription: string
  chooseImageLabel: string
  uploadHint: string
  optionsTitle: string
  optionsDescription: string
  widthLabel: string
  heightLabel: string
  keepAspectRatioLabel: string
  keepAspectRatioDescription: string
  allowUpscaleLabel: string
  allowUpscaleDescription: string
  algorithmLabel: string
  formatLabel: string
  qualityLabel: string
  qualityDescription: string
  resizeLabel: string
  resetLabel: string
  resultTitle: string
  resultDescription: string
  downloadLabel: string
  originalLabel: string
  outputLabel: string
  emptyResultTitle: string
  emptyResultDescription: string
  invalidImageTitle: string
  invalidImageDescription: string
  resizeErrorTitle: string
  resizeErrorDescription: string
  algorithmHighQuality: string
  algorithmBalanced: string
  algorithmPixelated: string
  formatAuto: string
  formatPng: string
  formatJpeg: string
  formatWebp: string
}>

type LocalizedSectionModule = {
  default: AstroComponentFactory
}

interface Props {
  lang: string
}

const { lang } = Astro.props

const metaModules = import.meta.glob("./meta/*.json", {
  eager: true,
  import: "default",
}) as Record<string, ToolMeta>
const messageModules = import.meta.glob("./messages/*.json", {
  eager: true,
  import: "default",
}) as Record<string, ImageResizerCopy>
const sectionModules = import.meta.glob("./sections/**/*.{md,mdx}")

function getLanguageFromPath(path: string) {
  return path.split("/").at(-1)?.replace(/\.(?:md|mdx|json)$/u, "") ?? "en"
}

function resolveLocalizedRecord<T>(
  modules: Record<string, T>,
  language: string,
  fileExtension: "json" | "md" | "mdx",
  basePath: string
) {
  const preferredKeys = [
    `${basePath}/${language}.${fileExtension}`,
    `${basePath}/en.${fileExtension}`,
  ]

  for (const key of preferredKeys) {
    if (key in modules) {
      return {
        data: modules[key],
        language: getLanguageFromPath(key),
      }
    }
  }

  const fallbackEntry = Object.entries(modules)[0]

  if (!fallbackEntry) {
    throw new Error(`Missing localized asset set at ${basePath}.`)
  }

  return {
    data: fallbackEntry[1],
    language: getLanguageFromPath(fallbackEntry[0]),
  }
}

async function loadLocalizedSection(section: string, language: string) {
  const preferredKeys = [
    `./sections/${section}/${language}.md`,
    `./sections/${section}/${language}.mdx`,
    `./sections/${section}/en.md`,
    `./sections/${section}/en.mdx`,
  ]

  for (const key of preferredKeys) {
    const importer = sectionModules[key]

    if (!importer) {
      continue
    }

    const loadedModule = (await importer()) as LocalizedSectionModule
    return loadedModule.default
  }

  return null
}

const { data: meta } = resolveLocalizedRecord(metaModules, lang, "json", "./meta")
const { data: copy } = resolveLocalizedRecord(
  messageModules,
  lang,
  "json",
  "./messages"
)
const IntroSection = await loadLocalizedSection("intro", lang)
const messages = {
  meta,
  ...copy,
}
---

<ToolPageShell title={meta.name} description={meta.description}>
  <ToolSurface className="space-y-5">
    <ImageResizerClient client:load messages={messages} />
  </ToolSurface>

  {
    IntroSection ? (
      <ToolSurface>
        <ToolArticle>
          <IntroSection />
        </ToolArticle>
      </ToolSurface>
    ) : null
  }
</ToolPageShell>
