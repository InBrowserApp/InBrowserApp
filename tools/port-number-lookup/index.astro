---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import PortNumberLookupClient from "./client"

import type { ToolMeta } from "@workspace/tool-sdk"

type PortNumberLookupMessages = Readonly<{
  searchPlaceholder: string
  all: string
  common: string
  system: string
  registered: string
  port: string
  service: string
  protocol: string
  description: string
  aboutTitle: string
  aboutDescription: string
  systemPorts: string
  systemPortsDesc: string
  registeredPorts: string
  registeredPortsDesc: string
  dynamicPorts: string
  dynamicPortsDesc: string
  noResultsTitle: string
  noResultsDescription: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<PortNumberLookupMessages>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <PortNumberLookupClient client:load language={lang} messages={messages} />
</ToolPageShell>
