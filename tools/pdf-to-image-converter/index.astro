---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolArticle } from "@workspace/ui/components/tool/tool-article"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import PdfToImageClient from "./client"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"
import type { ToolMeta } from "@workspace/tool-sdk"

type PdfToImageMessagesCatalog = Readonly<{
  addPdfLabel: string
  canvasExportFailedError: string
  canvasUnavailableError: string
  changePdfLabel: string
  downloadCurrentLabel: string
  downloadZipLabel: string
  dpiDescription: string
  dpiLabel: string
  dpiPresetLabel: string
  emptyPreviewDescription: string
  emptyPreviewTitle: string
  errorTitle: string
  exportAllLabel: string
  exportFailedError: string
  exportProgressLabel: string
  exportingAllLabel: string
  fileSizeLabel: string
  imageDetails: string
  invalidPdfError: string
  jpegFormat: string
  loadFailedError: string
  loadingDocumentLabel: string
  localOnlyNote: string
  outputFormatLabel: string
  pageCountLabel: string
  pageInputLabel: string
  pageLabel: string
  pageSummary: string
  pngFormat: string
  previewAlt: string
  previewDescription: string
  previewTitle: string
  qualityDescription: string
  qualityLabel: string
  removePdfLabel: string
  renderFailedError: string
  renderingPreviewDescription: string
  renderingPreviewTitle: string
  selectedPdfTitle: string
  settingsDescription: string
  settingsTitle: string
  supportedFormatsLabel: string
  unsupportedFileError: string
  uploadDescription: string
  uploadTitle: string
  webpFormat: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<PdfToImageMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const IntroSection = resolveLocale<AstroComponentFactory>(
  import.meta.glob("./sections/intro/*.{md,mdx}", {
    eager: true,
    import: "default",
  }),
  lang
)
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <PdfToImageClient client:load messages={messages} />

  {
    IntroSection ? (
      <ToolArticle>
        <IntroSection />
      </ToolArticle>
    ) : null
  }
</ToolPageShell>
