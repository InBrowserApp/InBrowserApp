---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import JsonFormatterClient from "./client"

import type { ToolMeta } from "@workspace/tool-sdk"

type JsonFormatterMessagesCatalog = Readonly<{
  importFromFileLabel: string
  downloadJsonLabel: string
  rawJsonLabel: string
  rawJsonDescription: string
  formattedJsonLabel: string
  formattedJsonDescription: string
  jsonPlaceholder: string
  invalidJsonLabel: string
  indentSizeLabel: string
  copyJsonLabel: string
  copiedLabel: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<JsonFormatterMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <JsonFormatterClient client:load messages={messages} />
</ToolPageShell>
