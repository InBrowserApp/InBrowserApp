---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import BasicAuthGeneratorClient from "./client"

import type { ToolMeta } from "@workspace/tool-sdk"

type BasicAuthGeneratorMessagesCatalog = Readonly<{
  credentialsLabel: string
  usernameLabel: string
  passwordLabel: string
  authorizationHeaderLabel: string
  curlExampleLabel: string
  copyResultLabel: string
  copiedLabel: string
  resetLabel: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<BasicAuthGeneratorMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <BasicAuthGeneratorClient client:load messages={messages} />
</ToolPageShell>
