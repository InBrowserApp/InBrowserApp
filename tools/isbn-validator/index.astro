---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolArticle } from "@workspace/ui/components/tool/tool-article"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import IsbnValidatorClient from "./client"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"
import type { ToolMeta } from "@workspace/tool-sdk"

type IsbnMessagesCatalog = Readonly<{
  isbn: string
  placeholder: string
  valid: string
  invalid: string
  invalidChecksum: string
  invalidLength: string
  invalidFormat: string
  result: string
  type: string
  normalized: string
  checksum: string
  checkDigit: string
  expected: string
  actual: string
  pass: string
  fail: string
  unknown: string
  isbn10: string
  isbn13: string
  prefix: string
  digits: string
  notAvailable: string
  notConvertible: string
  copyLabel: string
  copiedLabel: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<IsbnMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const IntroSection = resolveLocale<AstroComponentFactory>(
  import.meta.glob("./sections/intro/*.{md,mdx}", {
    eager: true,
    import: "default",
  }),
  lang
)
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <IsbnValidatorClient client:load messages={messages} />

  {
    IntroSection ? (
      <ToolArticle>
        <IntroSection />
      </ToolArticle>
    ) : null
  }
</ToolPageShell>
