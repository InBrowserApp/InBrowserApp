---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolArticle } from "@workspace/ui/components/tool/tool-article"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import VinValidatorClient from "./client"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"
import type { ToolMeta } from "@workspace/tool-sdk"

type VinMessagesCatalog = Readonly<{
  vin: string
  placeholder: string
  valid: string
  invalid: string
  invalidLength: string
  invalidCharacters: string
  invalidChecksum: string
  result: string
  status: string
  length: string
  lengthCheck: string
  characterCheck: string
  checkDigit: string
  expected: string
  actual: string
  normalized: string
  pass: string
  fail: string
  notAvailable: string
  allowedCharacters: string
  copyLabel: string
  copiedLabel: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<VinMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const IntroSection = resolveLocale<AstroComponentFactory>(
  import.meta.glob("./sections/intro/*.{md,mdx}", {
    eager: true,
    import: "default",
  }),
  lang
)
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <VinValidatorClient client:load messages={messages} />

  {
    IntroSection ? (
      <ToolArticle>
        <IntroSection />
      </ToolArticle>
    ) : null
  }
</ToolPageShell>
