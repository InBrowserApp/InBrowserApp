---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import UnicodePunycodeConverterClient from "./client"

import type { ToolMeta } from "@workspace/tool-sdk"

type UnicodePunycodeMessagesCatalog = Readonly<{
  asciiDomainLabel: string
  unicodeDomainLabel: string
  whatIsPunycodeTitle: string
  whatIsPunycodeDescription: string
  copyLabel: string
  copiedLabel: string
  resetLabel: string
}>

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<UnicodePunycodeMessagesCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const messages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <UnicodePunycodeConverterClient client:load messages={messages} />
</ToolPageShell>
