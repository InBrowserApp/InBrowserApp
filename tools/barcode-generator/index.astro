---
import { resolveLocale } from "@workspace/tool-sdk"
import { ToolPageShell } from "@workspace/ui/components/tool/tool-page-shell"
import BarcodeGeneratorClient from "./client"

import type { ToolMeta } from "@workspace/tool-sdk"
import type { BarcodeGeneratorMessages } from "./client/types"

type BarcodeGeneratorCatalog = Omit<BarcodeGeneratorMessages, "meta">

interface Props {
  lang: string
}

const { lang } = Astro.props

const meta = resolveLocale<ToolMeta>(
  import.meta.glob("./meta/*.json", { eager: true, import: "default" }),
  lang
)!
const localizedMessages = resolveLocale<BarcodeGeneratorCatalog>(
  import.meta.glob("./messages/*.json", { eager: true, import: "default" }),
  lang
)!
const messages: BarcodeGeneratorMessages = { meta, ...localizedMessages }
---

<ToolPageShell title={meta.name} description={meta.description}>
  <BarcodeGeneratorClient client:load messages={messages} />
</ToolPageShell>
