{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "paths": {
      "@/*": ["apps/web/src/*"],
      "@workspace/tool-sdk": ["packages/tool-sdk/src/index.ts"],
      "@workspace/tool-sdk/*": ["packages/tool-sdk/src/*"],
      "@workspace/ui/*": ["packages/ui/src/*"]
    }
  }
}
