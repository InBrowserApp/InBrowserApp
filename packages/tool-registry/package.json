{
  "name": "@workspace/tool-registry",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "generate": "tsx src/generate.ts && pnpm exec oxfmt src/generated/*.ts",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tool/base64-encoder-decoder": "workspace:*",
    "@tool/image-resizer": "workspace:*",
    "@tool/json-schema-validator": "workspace:*",
    "@workspace/tool-sdk": "workspace:*"
  },
  "peerDependencies": {
    "astro": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": "./src/index.ts",
    "./generate": "./src/generate.ts"
  }
}
