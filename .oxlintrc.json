{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "react", "jsx-a11y", "typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "max-lines": [
      "error",
      { "max": 300, "skipBlankLines": true, "skipComments": true }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/tests/**"],
      "rules": {
        "max-lines": "off"
      }
    },
    {
      "files": ["packages/tool-registry/src/generated/**"],
      "rules": {
        "max-lines": "off"
      }
    }
  ],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "dist/**",
    ".astro/**",
    ".turbo/**",
    ".agents/**",
    ".playwright-cli/**",
    "coverage/**",
    "node_modules/**"
  ],
  "settings": {
    "react": {
      "version": "19.2.4"
    }
  }
}
