{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "import",
    "react",
    "jsx-a11y",
    "typescript",
    "unicorn",
    "oxc",
    "vitest",
    "promise"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "max-lines": [
      "error",
      { "max": 300, "skipBlankLines": true, "skipComments": true }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/tests/**"],
      "rules": {
        "max-lines": "off",
        "vitest/require-mock-type-parameters": "off",
        "vitest/no-conditional-expect": "off",
        "vitest/valid-expect": "error",
        "vitest/expect-expect": [
          "error",
          {
            "assertFunctionNames": [
              "expect*",
              "screen.findBy*",
              "screen.findAllBy*",
              "screen.getBy*",
              "screen.getAllBy*"
            ]
          }
        ],
        "vitest/require-to-throw-message": "error"
      }
    },
    {
      "files": ["packages/tool-registry/src/generated/**"],
      "rules": {
        "max-lines": "off"
      }
    }
  ],
  "env": {
    "builtin": true,
    "browser": true,
    "node": true
  },
  "ignorePatterns": [
    "dist/**",
    ".astro/**",
    ".turbo/**",
    ".agents/**",
    ".playwright-cli/**",
    "coverage/**",
    "node_modules/**"
  ],
  "settings": {
    "react": {
      "version": "19.2.4"
    }
  }
}
