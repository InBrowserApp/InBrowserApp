{
  "name": "inbrowser-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "depcruise": "depcruise --config .dependency-cruiser.json apps/web/src packages/ui/src",
    "dev": "turbo dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "knip": "knip --config .knip.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "husky",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "dependency-cruiser": "^17.3.10",
    "husky": "^9.1.7",
    "knip": "^6.3.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
