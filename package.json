{
  "name": "inbrowser-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "pnpm tool-registry:generate && pnpm --filter web build",
    "depcruise": "depcruise --config .dependency-cruiser.json apps/web/src packages/ui/src packages/tool-sdk/src packages/tool-registry/src packages/lib tools",
    "dev": "pnpm tool-registry:generate && pnpm --filter web dev",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "knip": "knip --config .knip.json",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "prepare": "husky",
    "tool-registry:generate": "pnpm --filter @workspace/tool-registry generate",
    "test": "vitest run --silent",
    "test:coverage": "vitest run --silent --coverage",
    "typecheck": "pnpm tool-registry:generate && tsc --noEmit && pnpm --filter web typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "astro": "catalog:",
    "dependency-cruiser": "catalog:",
    "happy-dom": "catalog:",
    "husky": "catalog:",
    "knip": "catalog:",
    "lint-staged": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "patchedDependencies": {
      "curlconverter@4.12.0": "patches/curlconverter@4.12.0.patch"
    }
  }
}
