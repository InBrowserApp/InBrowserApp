---
import { LanguageSwitcher } from "@workspace/ui/components/app/language-switcher"
import { ThemeToggle } from "@workspace/ui/components/app/theme-toggle"
import {
  createLanguageOptions,
  localizePath,
  type SiteLanguage,
} from "@/lib/site"
import { loadSiteMessages } from "@/lib/site-messages"

interface Props {
  language: SiteLanguage
  current: "home" | "tools"
  pathname: string
  availableLanguages?: readonly SiteLanguage[]
}

const { language, current, pathname, availableLanguages } = Astro.props
const { catalog } = loadSiteMessages(language)
const languageOptions = createLanguageOptions(
  pathname,
  language,
  availableLanguages
)
const navItems = [
  { id: "tools" as const, href: localizePath("/tools", language), label: catalog.site.navigation.tools },
]
---

<nav class="flex items-center justify-between">
  <div class="flex items-center gap-4">
    <a
      href={localizePath("/", language)}
      aria-current={current === "home" ? "page" : undefined}
      class="rounded-sm text-sm font-semibold text-foreground outline-none focus-visible:ring-3 focus-visible:ring-ring/50"
    >
      {catalog.site.name}
    </a>
    {navItems.map((item) => (
      <a
        href={item.href}
        aria-current={item.id === current ? "page" : undefined}
        class:list={[
          "rounded-sm text-sm transition-colors outline-none hover:text-foreground focus-visible:ring-3 focus-visible:ring-ring/50",
          item.id === current ? "text-foreground" : "text-muted-foreground",
        ]}
      >
        {item.label}
      </a>
    ))}
  </div>
  <div class="flex items-center gap-1">
    <ThemeToggle
      client:idle
      transition:persist="theme-toggle"
      labelLight={catalog.site.themeLight}
      labelDark={catalog.site.themeDark}
      labelSystem={catalog.site.themeSystem}
      srLabel={catalog.site.themeLabel}
    />
    <div class="mx-1 h-4 w-px bg-border" aria-hidden="true" />
    <LanguageSwitcher
      client:idle
      transition:persist="lang-switcher"
      label={catalog.site.languageLabel}
      options={languageOptions}
    />
  </div>
</nav>
