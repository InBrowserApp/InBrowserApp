---
import { toolRegistry, toolSearchIndex } from "@workspace/tool-registry"
import { SiteFrame } from "@workspace/ui/components/app/site-frame"
import { SectionHeading } from "@workspace/ui/components/app/section-heading"
import { Button } from "@workspace/ui/components/ui/button"
import { ToolSurface } from "@workspace/ui/components/tool/tool-surface"
import { ArrowRight, LayoutGrid, Search, Wrench } from "@workspace/ui/icons"
import MainLayout from "@/layouts/main.astro"
import { loadSitePageContent } from "@/lib/site-content"
import { loadSiteMessages } from "@/lib/site-messages"
import { createPageSeo } from "@/lib/seo"
import {
  SUPPORTED_SITE_LANGUAGES,
  localizePath,
  type SiteLanguage,
} from "@/lib/site"
import type { AstroComponentFactory } from "astro/runtime/server/index.js"

interface Props {
  language: SiteLanguage
}

const { language } = Astro.props
const { catalog } = loadSiteMessages(language)
const { Content: ToolsContent } = await loadSitePageContent("tools", language)
const seo = createPageSeo({
  description: catalog.metadata.toolsDescription,
  language,
  pathname: "/tools",
  title: catalog.metadata.toolsTitle,
})
const Content = ToolsContent as AstroComponentFactory | null
---

<MainLayout
  alternateLinks={seo.alternateLinks}
  canonicalUrl={seo.canonicalUrl}
  description={seo.description}
  lang={language}
  title={seo.title}
>
  <SiteFrame
    eyebrow={catalog.tools.eyebrow}
    title={catalog.tools.title}
    description={catalog.tools.description}
  >
    <div class="flex flex-wrap items-center gap-3">
      <Button asChild variant="outline">
        <a href={localizePath("/", language)}>
          {catalog.site.navigation.home}
          <ArrowRight />
        </a>
      </Button>
      {
        SUPPORTED_SITE_LANGUAGES.map((alternateLanguage) => (
          <Button asChild variant="ghost" size="sm">
            <a href={localizePath("/tools", alternateLanguage)}>
              {catalog.site.languages[alternateLanguage]}
            </a>
          </Button>
        ))
      }
    </div>

    <div class="grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.85fr)]">
      <ToolSurface className="flex flex-col gap-6">
        <SectionHeading
          eyebrow={catalog.tools.metricsTitle}
          title={catalog.tools.emptyTitle}
          description={catalog.tools.emptyDescription}
        />
        <div class="grid gap-4 sm:grid-cols-3">
          <ToolSurface className="flex flex-col gap-3 border-dashed shadow-none">
            <Wrench className="size-5 text-muted-foreground" />
            <div class="space-y-1">
              <p class="text-sm text-muted-foreground">
                {catalog.tools.registryCountLabel}
              </p>
              <p class="font-heading text-3xl text-foreground">{toolRegistry.length}</p>
            </div>
          </ToolSurface>
          <ToolSurface className="flex flex-col gap-3 border-dashed shadow-none">
            <Search className="size-5 text-muted-foreground" />
            <div class="space-y-1">
              <p class="text-sm text-muted-foreground">
                {catalog.tools.searchIndexLabel}
              </p>
              <p class="font-heading text-3xl text-foreground">{toolSearchIndex.length}</p>
            </div>
          </ToolSurface>
          <ToolSurface className="flex flex-col gap-3 border-dashed shadow-none">
            <LayoutGrid className="size-5 text-muted-foreground" />
            <div class="space-y-1">
              <p class="text-sm text-muted-foreground">
                {catalog.tools.languageCountLabel}
              </p>
              <p class="font-heading text-3xl text-foreground">
                {SUPPORTED_SITE_LANGUAGES.length}
              </p>
            </div>
          </ToolSurface>
        </div>
      </ToolSurface>
      <ToolSurface className="flex flex-col gap-4">
        <SectionHeading
          eyebrow={catalog.tools.contentHeading}
          title={catalog.tools.metricsTitle}
          description={catalog.tools.description}
        />
        <div class="space-y-3 text-sm leading-6 text-muted-foreground">
          <p>{catalog.tools.emptyDescription}</p>
          <p>{catalog.tools.loadingModelDescription}</p>
        </div>
      </ToolSurface>
    </div>

    {
      Content ? (
        <ToolSurface className="space-y-5">
          <SectionHeading
            eyebrow={catalog.tools.contentHeading}
            title={catalog.tools.metricsTitle}
            description={catalog.tools.description}
          />
          <article class="space-y-4 text-sm leading-7 text-muted-foreground sm:text-base">
            <Content />
          </article>
        </ToolSurface>
      ) : null
    }
  </SiteFrame>
</MainLayout>
