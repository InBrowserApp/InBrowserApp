---
import MainLayout from "@/layouts/main.astro"
import SiteNavbar from "@/components/site-navbar.astro"
import { createPageSeo } from "@/lib/seo"
import { loadSiteMessages } from "@/lib/site-messages"
import { loadToolPageData } from "@/lib/tool-pages"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"
import type { SiteLanguage } from "@/lib/site"

interface Props {
  language: SiteLanguage
  slug: string
}

const { language, slug } = Astro.props
const { catalog } = loadSiteMessages(language)
const pageData = await loadToolPageData(slug, language)

if (!pageData) {
  throw new Error(`Unknown tool slug '${slug}'.`)
}

const seo = createPageSeo({
  availableLanguages: pageData.availableLanguages,
  description: pageData.meta.description,
  language,
  pathname: `/tools/${slug}`,
  title: `${pageData.meta.name} · ${catalog.metadata.toolTitleSuffix}`,
})
const Page = pageData.Page as AstroComponentFactory | null
---

<MainLayout
  alternateLinks={seo.alternateLinks}
  canonicalUrl={seo.canonicalUrl}
  description={seo.description}
  lang={language}
  title={seo.title}
>
  <div class="min-h-svh bg-background">
    <div class="mx-auto flex w-full max-w-6xl flex-col gap-8 px-[var(--spacing-page-x)] py-[var(--spacing-page-y)]">
      <SiteNavbar
        language={language}
        current="tools"
        pathname={`/tools/${slug}`}
        availableLanguages={pageData.availableLanguages}
      />

      {
        Page ? (
          <Page lang={language} />
        ) : (
          <div class="rounded-xl border border-dashed border-border/80 bg-muted/30 px-6 py-12 text-center text-sm text-muted-foreground">
            {catalog.tools.emptyRegistryDescription}
          </div>
        )
      }
    </div>
  </div>
</MainLayout>
