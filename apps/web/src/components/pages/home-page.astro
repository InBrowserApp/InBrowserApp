---
import { toolRegistry, toolSearchIndex } from "@workspace/tool-registry"
import { SectionHeading } from "@workspace/ui/components/app/section-heading"
import { SiteFrame } from "@workspace/ui/components/app/site-frame"
import { SiteToolbar } from "@workspace/ui/components/app/site-toolbar"
import { Button } from "@workspace/ui/components/ui/button"
import { ToolSurface } from "@workspace/ui/components/tool/tool-surface"
import { ArrowRight, Languages, LayoutGrid } from "@workspace/ui/icons"
import MainLayout from "@/layouts/main.astro"
import { loadSitePageContent } from "@/lib/site-content"
import { loadSiteMessages } from "@/lib/site-messages"
import { createPageSeo } from "@/lib/seo"
import { createSiteToolbarData } from "@/lib/site-shell"
import {
  SUPPORTED_SITE_LANGUAGES,
  localizePath,
  type SiteLanguage,
} from "@/lib/site"

import type { AstroComponentFactory } from "astro/runtime/server/index.js"

interface Props {
  language: SiteLanguage
}

const { language } = Astro.props
const { catalog } = loadSiteMessages(language)
const { Content: HomeContent } = await loadSitePageContent("home", language)
const seo = createPageSeo({
  description: catalog.metadata.homeDescription,
  language,
  pathname: "/",
  title: catalog.metadata.homeTitle,
})
const Content = HomeContent as AstroComponentFactory | null
const shell = createSiteToolbarData("/", language, catalog, "home")
const numberFormatter = new Intl.NumberFormat(language)
const stats = [
  {
    detail: catalog.home.toolCountDetail,
    label: catalog.home.toolCountLabel,
    value: numberFormatter.format(toolRegistry.length),
  },
  {
    detail: catalog.home.searchCountDetail,
    label: catalog.home.searchCountLabel,
    value: numberFormatter.format(toolSearchIndex.length),
  },
  {
    detail: catalog.home.languageCountDetail,
    label: catalog.home.languageCountLabel,
    value: numberFormatter.format(SUPPORTED_SITE_LANGUAGES.length),
  },
] as const
const principles = [
  {
    description: catalog.home.registryDescription,
    icon: LayoutGrid,
    title: catalog.home.registryTitle,
  },
  {
    description: catalog.home.localeDescription,
    icon: Languages,
    title: catalog.home.localeTitle,
  },
] as const
---

<MainLayout
  alternateLinks={seo.alternateLinks}
  canonicalUrl={seo.canonicalUrl}
  description={seo.description}
  lang={language}
  title={seo.title}
>
  <SiteFrame
    eyebrow={catalog.home.eyebrow}
    title={catalog.home.title}
    description={catalog.home.description}
  >
    <SiteToolbar {...shell} />

    <ToolSurface className="flex flex-col gap-6">
      <div class="flex flex-wrap items-center gap-3">
        <Button asChild>
          <a href={localizePath("/tools", language)}>
            {catalog.home.primaryAction}
            <ArrowRight data-icon="inline-end" />
          </a>
        </Button>
        <Button asChild variant="outline">
          <a href="#rewrite-notes">{catalog.home.secondaryAction}</a>
        </Button>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        {
          stats.map((stat) => (
            <ToolSurface className="flex flex-col gap-3 border-dashed bg-background/70 shadow-none">
              <p class="text-sm font-medium text-foreground">{stat.label}</p>
              <p class="font-heading text-3xl leading-none tracking-[var(--tracking-display)] text-foreground">
                {stat.value}
              </p>
              <p class="text-sm leading-6 text-muted-foreground">{stat.detail}</p>
            </ToolSurface>
          ))
        }
      </div>
    </ToolSurface>

    <section class="grid gap-6 lg:grid-cols-[minmax(0,1.2fr)_minmax(18rem,0.8fr)]">
      <ToolSurface className="space-y-6">
        <SectionHeading
          eyebrow={catalog.home.principlesEyebrow}
          title={catalog.home.principlesTitle}
          description={catalog.home.principlesDescription}
        />

        <div class="grid gap-4 md:grid-cols-2">
          {
            principles.map((principle) => {
              const Icon = principle.icon

              return (
                <ToolSurface className="flex h-full flex-col gap-4 border-dashed bg-background/70 shadow-none">
                  <Icon className="size-5 text-muted-foreground" />
                  <div class="space-y-2">
                    <h3 class="font-heading text-2xl leading-tight tracking-[var(--tracking-display)]">
                      {principle.title}
                    </h3>
                    <p class="text-sm leading-6 text-muted-foreground">
                      {principle.description}
                    </p>
                  </div>
                </ToolSurface>
              )
            })
          }
        </div>
      </ToolSurface>

      <ToolSurface className="space-y-5">
        <SectionHeading
          title={catalog.home.sidebarTitle}
          description={catalog.home.sidebarDescription}
        />

        <div class="space-y-4 text-sm leading-6 text-muted-foreground">
          <p>{catalog.site.description}</p>
          <p>{catalog.site.footerNote}</p>
        </div>

        <div class="grid gap-3">
          <div class="rounded-[calc(var(--radius)*1.4)] border border-dashed border-border/80 bg-muted/30 p-4">
            <p class="font-medium text-foreground">{catalog.home.registryTitle}</p>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {catalog.home.registryDescription}
            </p>
          </div>
          <div class="rounded-[calc(var(--radius)*1.4)] border border-dashed border-border/80 bg-muted/30 p-4">
            <p class="font-medium text-foreground">{catalog.home.localeTitle}</p>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {catalog.home.localeDescription}
            </p>
          </div>
          <div class="rounded-[calc(var(--radius)*1.4)] border border-dashed border-border/80 bg-muted/30 p-4">
            <p class="font-medium text-foreground">{catalog.home.shellTitle}</p>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {catalog.home.shellDescription}
            </p>
          </div>
        </div>
      </ToolSurface>
    </section>

    <section
      id="rewrite-notes"
      class="grid gap-6 lg:grid-cols-[minmax(0,1.15fr)_minmax(18rem,0.85fr)]"
    >
      {
        Content ? (
          <ToolSurface className="space-y-5">
            <SectionHeading
              eyebrow={catalog.home.contentEyebrow}
              title={catalog.home.contentTitle}
              description={catalog.home.contentDescription}
            />
            <article class="space-y-4 text-sm leading-7 text-muted-foreground sm:text-base">
              <Content />
            </article>
          </ToolSurface>
        ) : null
      }

      <ToolSurface className="space-y-5">
        <SectionHeading
          title={catalog.home.contentTitle}
          description={catalog.home.contentDescription}
        />

        <div class="space-y-4 text-sm leading-6 text-muted-foreground">
          <p>{catalog.site.tagline}</p>
          <p>{catalog.site.footerNote}</p>
        </div>

        <div class="space-y-4">
          <div class="rounded-[calc(var(--radius)*1.4)] border border-border/80 bg-muted/30 p-4">
            <p class="font-medium text-foreground">{catalog.home.registryTitle}</p>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {catalog.home.registryDescription}
            </p>
          </div>
          <div class="rounded-[calc(var(--radius)*1.4)] border border-border/80 bg-muted/30 p-4">
            <p class="font-medium text-foreground">{catalog.home.localeTitle}</p>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {catalog.home.localeDescription}
            </p>
          </div>
          <div class="rounded-[calc(var(--radius)*1.4)] border border-border/80 bg-muted/30 p-4">
            <p class="font-medium text-foreground">{catalog.home.shellTitle}</p>
            <p class="mt-2 text-sm leading-6 text-muted-foreground">
              {catalog.home.shellDescription}
            </p>
          </div>
        </div>
      </ToolSurface>
    </section>
  </SiteFrame>
</MainLayout>
